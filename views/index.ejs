<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>사진보관함</title>
</head>
<body>
  <h2>사진 업로드</h2>
  <form action="/upload" method="POST" enctype="multipart/form-data">
    <label>날짜 선택: <input type="date" name="date" required></label><br><br>
    <label>사진 선택: <input type="file" name="photo" accept="image/*" required></label><br><br>
    <button type="submit">업로드</button>
  </form>
</body>
</html>
