<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>사진보관함</title>
<style>
  body { font-family: sans-serif; padding: 10px; }
  h2 { text-align: center; }

  form { display: flex; flex-direction: column; gap: 10px; margin-bottom: 10px; }
  button { padding: 10px; background-color: #4CAF50; color: white; border: none; border-radius: 5px; cursor: pointer; }
  #deleteBtn { width: 100%; margin-bottom: 20px; } /* 업로드 버튼과 동일 길이 */

  .gallery { display: flex; flex-wrap: wrap; gap: 10px; justify-content: space-between; }
  .gallery div { width: 32%; position: relative; margin-bottom: 10px; } /* 한 줄 3장 */
  .gallery img { width: 100%; height: 100px; object-fit: cover; border-radius: 5px; cursor: pointer; }
  .checkbox { position: absolute; top: 5px; left: 5px; background: white; border-radius: 3px; }
</style>
</head>
<body>
<h2>사진보관함</h2>
<form id="uploadForm">
  <input type="date" name="date" required>
  <input type="file" name="photo" accept="image/*" required>
  <button type="submit">업로드</button>
</form>
<button id="deleteBtn">선택 사진 삭제</button>

<div class="gallery" id="gallery">
  <% images.forEach(img => { %>
    <div>
      <input type="checkbox" class="checkbox" data-filename="<%= img %>">
      <img src="/uploads/<%= img %>" alt="photo">
    </div>
  <% }) %>
</div>

<script>
const form = document.getElementById('uploadForm');
const gallery = document.getElementById('gallery');
const deleteBtn = document.getElementById('deleteBtn');

// 업로드
form.addEventListener('submit', async (e) => {
  e.preventDefault();
  const formData = new FormData(form);
  const res = await fetch('/upload', { method: 'POST', body: formData });
  const data = await res.json();
  if(data.success){
    const div = document.createElement('div');
    div.innerHTML = `<input type="checkbox" class="checkbox" data-filename="${data.filename}">
                     <img src="${data.filePath}" alt="photo">`;
    gallery.prepend(div);
  }
});

// 갤러리 클릭 → 원본 보기
gallery.addEventListener('click', (e) => {
  if(e.target.tagName === 'IMG'){
    window.open(e.target.src, '_blank');
  }
});

// 선택 삭제
deleteBtn.addEventListener('click', async () => {
  const checkboxes = document.querySelectorAll('.checkbox:checked');
  if(checkboxes.length === 0) return alert("선택된 사진이 없습니다.");
  const filenames = Array.from(checkboxes).map(cb => cb.dataset.filename);
  const res = await fetch('/delete', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ filenames })
  });
  const data = await res.json();
  if(data.success){
    checkboxes.forEach(cb => cb.parentElement.remove());
  }
});
</script>
</body>
</html>
